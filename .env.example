# ── API 密钥（每个服务商独立配置） ──
OPENAI_API_KEY=sk-your-api-key-here
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DASHSCOPE_API_KEY=sk-your-qwen-key
# MOONSHOT_API_KEY=sk-your-kimi-key
# ZHIPUAI_API_KEY=your-zhipu-key
# BAIDU_API_KEY=your-baidu-key
# GROQ_API_KEY=gsk_your-groq-key
# TOGETHER_API_KEY=your-together-key
# SILICONFLOW_API_KEY=sk-your-siliconflow-key
# LINGYIWANWU_API_KEY=your-lingyi-key

# ── 默认服务商（与 providers.json 中 name 一致） ──
# 可选: OpenAI | DeepSeek | 通义千问 | Moonshot (Kimi) | 智谱 GLM | 百度文心 | 零一万物 | Groq | Together AI | 硅基流动 | Ollama (本地) | 自定义
PROVIDER=OpenAI

# ── 自定义服务商（当 PROVIDER=自定义 时生效） ──
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# ── 模型参数 ──
TEMPERATURE=0.7
MAX_TOKENS=2048
MAX_HISTORY=100

# ── 系统提示词 ──
SYSTEM_PROMPT=你是一个智能助手，请用中文回答用户的问题。